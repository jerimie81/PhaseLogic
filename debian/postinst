#!/bin/sh
set -e

# Ensure the system config dir exists with the default config
if [ ! -f /etc/phaselogic/config.toml ]; then
    mkdir -p /etc/phaselogic
    # shipped default is already in /etc/phaselogic/config.toml via the package
    true
fi

echo "PhaseLogic installed."
echo ""
echo "  Add your API keys to: /etc/phaselogic/config.toml"
echo "  Or per-user at:       ~/.config/phaselogic/config.toml"
echo ""
echo "  Usage: phaselogic new \"describe your project\""
echo ""

#DEBHELPER#
exit 0
